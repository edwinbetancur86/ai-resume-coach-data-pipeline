# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real key. `.env` is git-ignored.
#   Windows:  copy .env.example .env
#   macOS/Linux:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────

# --- LLM provider (OpenRouter, OpenAI-compatible endpoint) ---------------
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models. OpenRouter uses "vendor/model" ids. Generator can be more creative;
# judge/corrector should be cheaper + more deterministic.
GENERATOR_MODEL=openai/gpt-4o-mini
JUDGE_MODEL=openai/gpt-4o-mini
CORRECTOR_MODEL=openai/gpt-4o-mini

# --- Sampling temperatures -----------------------------------------------
# Generator gets variety; judge/corrector run near-deterministic (low temp).
GENERATOR_TEMPERATURE=0.8
JUDGE_TEMPERATURE=0.0
CORRECTOR_TEMPERATURE=0.2

# --- Optional observability (Phase: bonus) -------------------------------
# Leave blank to disable. Braintrust for eval logging, Logfire for tracing.
BRAINTRUST_API_KEY=
LOGFIRE_TOKEN=

# --- Run knobs (safe defaults; overridable via CLI flags) ----------------
REQUEST_TIMEOUT_SECONDS=60
API_CALL_DELAY_SECONDS=0.3
